# ──────────────────────────────────────────────────────────────────
#  WebScan — environment variable reference
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8080

# ── Safety limits ──────────────────────────────────────────────────
# Max concurrent check coroutines per scan
MAX_CONCURRENT_CHECKS=3

# Per-request timeout in seconds
REQUEST_TIMEOUT_SEC=8.0

# Maximum outbound requests per scan session
MAX_REQUESTS_PER_SCAN=50

# Delay between consecutive requests (seconds)
DELAY_BETWEEN_REQS_SEC=0.5

# Optional allowlist: only scan URLs matching this regex.
# Leave blank to allow any public URL.
# Example: ^https://staging\.mycompany\.com
ALLOWED_TARGETS_REGEX=

# ── Reporting ──────────────────────────────────────────────────────
# Directory where generated reports are stored (leave blank for in-memory only)
REPORT_STORE_DIR=

# ── SLM / LLM Agents (optional) ────────────────────────────────────
# Set to true to enable Ollama-backed agent analysis
ENABLE_SLM_AGENTS=false

# Ollama API base URL
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model name (must be pulled in Ollama: `ollama pull llama3`)
SLM_MODEL=llama3

# ── Suppression ────────────────────────────────────────────────────
# Path to YAML suppression file (see suppression.yaml for format)
SUPPRESSION_FILE=suppression.yaml

# ── Logging ────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to audit log file
AUDIT_LOG_FILE=audit.jsonl
